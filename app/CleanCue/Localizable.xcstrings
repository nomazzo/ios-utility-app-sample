    "onboarding.tasks.footer": {
      "comment": "Footer text in onboarding task selection for Pro users. It explains recommended task count, first due date distribution, and later editing.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with 2-3 tasks per place. First due dates are spread out and can be changed later. Deselect anything you do not need."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初は各場所2〜3件がおすすめです。初回予定日は分散され、あとから変更できます。不要なものは外せます。"
          }
        }
      }
    },
    "onboarding.tasks.freeLimitFooter": {
      "comment": "Footer text in onboarding task selection for free users. It explains recommended task count, first due date distribution, later editing, and the free task limit.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with 2-3 tasks per place. First due dates are spread out and can be changed later. The free plan lets you choose up to 20 tasks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初は各場所2〜3件がおすすめです。初回予定日は分散され、あとから変更できます。無料版では20件まで選べます。"
          }
        }
      }
    },
